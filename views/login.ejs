<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Arima:wght@100..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <title>Login</title>
</head>
<body>
    <section class="main1" style="text-align: center;">
        <h1>Login</h1>
        <form method="post" action="/login">
            <div style="margin-bottom: 15px;">
                <input type="email" name="email" placeholder="Email" required style="padding: 8px; width: 80%;">
            </div>
            <div style="margin-bottom: 15px;">
                <input type="password" name="password" placeholder="Password" required style="padding: 8px; width: 80%;">
            </div>
            <button style="padding: 8px 20px; background-color: #333; color: white; border: none; border-radius: 5px; cursor: pointer;">Login</button>
        </form>
        <br>
        <p>Don't have an account? <a href="/register" style="color: blue; text-decoration: underline;">Register here</a></p>
    </section>
</body>
</html>